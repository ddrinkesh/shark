{{ 'icon-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }} section-{{ section.id }}-padding section-{{ section.id }}-margin color-{{ section.settings.color_scheme }} gradient section-main-box icon-with-text-main">
  <div class="icon-with-text-container page-width">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="icon-with-text-header icon-with-text-header--{{ section.settings.text_alignment }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="icon-with-text-heading inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="icon-with-text-description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="icon-with-text-grid icon-with-text-grid--{{ section.settings.columns_desktop }} icon-with-text-grid--mobile-{{ section.settings.columns_mobile }}">
      {%- for block in section.blocks -%}
        <div class="icon-with-text-item icon-with-text-item--{{ section.settings.card_alignment }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank or block.settings.icon != 'none' -%}
            <div class="icon-with-text-icon" style="--icon-size: {{ section.settings.icon_size }}px;">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 180
                  | image_tag:
                    widths: '60, 90, 120, 180',
                    loading: 'lazy',
                    class: 'icon-with-text-image'
                }}
              {%- else -%}
                {%- render 'icon-accordion', icon: block.settings.icon -%}
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h3 class="icon-with-text-item-heading inline-richtext">{{ block.settings.heading }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="icon-with-text-item-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icon With Text",
  "tag": "section",
  "class": "icon-with-text-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Why shop with us"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add trust-building details, product benefits, or service highlights.</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "card_alignment",
      "label": "Item alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 24,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 35
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Icon item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "box",
              "label": "Box"
            },
            {
              "value": "check_mark",
              "label": "Check mark"
            },
            {
              "value": "heart",
              "label": "Heart"
            },
            {
              "value": "leaf",
              "label": "Leaf"
            },
            {
              "value": "lock",
              "label": "Lock"
            },
            {
              "value": "plane",
              "label": "Plane"
            },
            {
              "value": "price_tag",
              "label": "Price tag"
            },
            {
              "value": "recycle",
              "label": "Recycle"
            },
            {
              "value": "return",
              "label": "Return"
            },
            {
              "value": "star",
              "label": "Star"
            },
            {
              "value": "stopwatch",
              "label": "Stopwatch"
            },
            {
              "value": "truck",
              "label": "Truck"
            }
          ],
          "default": "truck"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom icon image"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Fast shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share a short benefit or service promise with your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon With Text",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "heading": "Fast shipping",
            "text": "<p>Quick delivery options for every order.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "return",
            "heading": "Easy returns",
            "text": "<p>Simple returns when something is not right.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "lock",
            "heading": "Secure checkout",
            "text": "<p>Your payment details stay protected.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
