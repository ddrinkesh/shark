{{ 'membership-card-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }} section-{{ section.id }}-padding section-{{ section.id }}-margin color-{{ section.settings.color_scheme }} gradient section-main-box membership-card-grid-main">
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.text != blank or section.settings.eyebrow != blank -%}
      <div class="membership-card-grid-header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="membership-card-grid-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="membership-card-grid-heading inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="membership-card-grid-text rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="membership-card-grid-items">
      {%- for block in section.blocks -%}
        <article class="membership-card-grid-card" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="membership-card-grid-link" aria-label="{{ block.settings.heading | default: block.settings.link_label | default: 'Membership card' | escape }}">
          {%- endif -%}
            <div class="membership-card-grid-media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: widths: '300, 500, 700, 900, 1000', sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw', loading: 'lazy', class: 'membership-card-grid-image' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg membership-card-grid-placeholder' }}
              {%- endif -%}
            </div>
            <div class="membership-card-grid-content">
              {%- if block.settings.heading != blank -%}
                <h3 class="membership-card-grid-title inline-richtext">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="membership-card-grid-copy rte">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.link_label != blank -%}
                <span class="membership-card-grid-button link animate-arrow">{{ block.settings.link_label | escape }}<span class="svg-wrapper"><span class="icon-wrap">&nbsp;{{ 'icon-arrow.svg' | inline_asset_content }}</span></span></span>
              {%- endif -%}
            </div>
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div class="membership-card-grid-footer">
        <a class="button" {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.button_link }}"{% endif %}>{{ section.settings.button_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Membership card grid",
  "tag": "section",
  "class": "membership-card-grid-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Get more from our tips"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Member resources and ideas"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Resource title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add a short description for this membership resource.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Read more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Membership card grid",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
