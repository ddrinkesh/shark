{{ 'image-text-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign image_ratio_class = 'image-text-slider-card__media--' | append: section.settings.image_ratio
-%}

{%- capture slider_options -%}
  "slidesPerView": 1.5,
  "spaceBetween": 16,
  "loop": {{ section.settings.enable_loop }},
  "speed": {% if section.settings.enable_loop %}{{ section.settings.slider_speed }}{% else %}400{% endif %},
  {% if section.settings.enable_loop %}
  "allowTouchMove": false,
  "autoplay": {
    "delay": 0,
    "disableOnInteraction": false,
    "reverseDirection": true
  },
  {% endif %}
  {% if section.settings.show_pagination %}
  "pagination": {
    "el": "#shopify-section-{{ section.id }} .swiper-pagination",
    "clickable": true
  },
  {% endif %}
  {% if section.settings.navigation %}
  "navigation": {
    "nextEl": "#shopify-section-{{ section.id }} .swiper-button-next",
    "prevEl": "#shopify-section-{{ section.id }} .swiper-button-prev"
  },
  {% endif %}
  "breakpoints": {
    "0": {
      "slidesPerView": 1.5,
      "spaceBetween": 16
    },
    "750": {
      "slidesPerView": 2.5,
      "spaceBetween": 20
    },
    "990": {
      "slidesPerView": {% if section.settings.auto_width %}"auto"{% else %}4{% endif %},
      "spaceBetween": {{ section.settings.space_between_slide }}
    }
  }
{%- endcapture -%}

<div class="section-{{ section.id }} section-{{ section.id }}-padding section-{{ section.id }}-margin color-{{ section.settings.color_scheme }} gradient section-main-box image-text-slider-main{% if section.settings.enable_loop %} image-text-slider-main--loop{% endif %}">
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="image-text-slider-header {{ section.settings.heading_alignment }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="image-text-slider-heading inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="image-text-slider-text rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {% if section.settings.enable_slider %}
      <div class="swiper-main-wrapper image-text-slider-wrapper">
        <div class="swiper image-text-slider-swiper" data-slider-options='{ {{ slider_options }} }'>
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide image-text-slider-slide{% if section.settings.auto_width %} auto-width{% endif %}" {{ block.shopify_attributes }}>
                <div class="image-text-slider-card">
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="image-text-slider-card__link" aria-label="{{ block.settings.title | default: block.settings.link_label | default: 'Image text slide' | escape }}">
                  {%- endif -%}
                    <div
                      class="image-text-slider-card__media {{ image_ratio_class }}"
                      {% if section.settings.image_ratio == 'adapt' and block.settings.image != blank %}
                        style="aspect-ratio: {{ block.settings.image.aspect_ratio }};"
                      {% endif %}
                    >
                      {%- if block.settings.image != blank -%}
                        {{
                          block.settings.image
                          | image_url: width: 1200
                          | image_tag:
                            loading: 'lazy',
                            widths: '300, 400, 500, 600, 750, 900, 1200',
                            sizes: '(min-width: 990px) 25vw, (min-width: 750px) 40vw, 70vw',
                            class: 'image-text-slider-card__image'
                        }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg image-text-slider-card__placeholder' }}
                      {%- endif -%}
                    </div>
                    {%- if block.settings.title != blank or block.settings.text != blank or block.settings.link_label != blank -%}
                      <div class="image-text-slider-card__content {{ section.settings.text_alignment }}">
                        {%- if block.settings.title != blank -%}
                          <h3 class="image-text-slider-card__title inline-richtext">{{ block.settings.title }}</h3>
                        {%- endif -%}
                        {%- if block.settings.text != blank -%}
                          <div class="image-text-slider-card__text rte">{{ block.settings.text }}</div>
                        {%- endif -%}
                        {%- if block.settings.link_label != blank -%}
                          <span class="image-text-slider-card__button link animate-arrow">
                            {{- block.settings.link_label | escape -}}
                            <span class="svg-wrapper"><span class="icon-wrap">&nbsp;{{ 'icon-arrow.svg' | inline_asset_content }}</span></span>
                          </span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        {% if section.settings.navigation %}
          <div class="nav-btns image-text-slider-nav {% if section.settings.show_navigation_in == 'desktop' %}small-hide{% endif %} {% if section.settings.show_navigation_in == 'mobile' %}medium-hide large-up-hide{% endif %}">
            <div class="btn-arrow swiper-button-prev" aria-label="Previous slide">{{ 'icon-caret.svg' | inline_asset_content }}</div>
            <div class="btn-arrow swiper-button-next" aria-label="Next slide">{{ 'icon-caret.svg' | inline_asset_content }}</div>
          </div>
        {% endif %}

        {% if section.settings.show_pagination %}
          <div class="swiper-pagination {{ section.settings.pagination_type }} {% if section.settings.show_pagination_in == 'desktop' %}small-hide{% endif %} {% if section.settings.show_pagination_in == 'mobile' %}medium-hide large-up-hide{% endif %}"></div>
        {% endif %}
      </div>
    {% else %}
      <div class="image-text-slider-items">
        {% for block in section.blocks %}
          <div class="image-text-slider-item" {{ block.shopify_attributes }}>
            <div class="image-text-slider-card">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="image-text-slider-card__link" aria-label="{{ block.settings.title | default: block.settings.link_label | default: 'Image text item' | escape }}">
              {%- endif -%}
                <div
                  class="image-text-slider-card__media {{ image_ratio_class }}"
                  {% if section.settings.image_ratio == 'adapt' and block.settings.image != blank %}
                    style="aspect-ratio: {{ block.settings.image.aspect_ratio }};"
                  {% endif %}
                >
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        widths: '300, 400, 500, 600, 750, 900, 1200',
                        sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                        class: 'image-text-slider-card__image'
                    }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg image-text-slider-card__placeholder' }}
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank or block.settings.text != blank or block.settings.link_label != blank -%}
                  <div class="image-text-slider-card__content {{ section.settings.text_alignment }}">
                    {%- if block.settings.title != blank -%}
                      <h3 class="image-text-slider-card__title inline-richtext">{{ block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="image-text-slider-card__text rte">{{ block.settings.text }}</div>
                    {%- endif -%}
                    {%- if block.settings.link_label != blank -%}
                      <span class="image-text-slider-card__button link animate-arrow">
                        {{- block.settings.link_label | escape -}}
                        <span class="svg-wrapper"><span class="icon-wrap">&nbsp;{{ 'icon-arrow.svg' | inline_asset_content }}</span></span>
                      </span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Image text slider",
  "class": "image-text-slider-wrapper",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Image text slider"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Heading alignment"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Card text alignment"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "header",
      "content": "Slider Options"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "default": true,
      "label": "Enable Slider"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "default": true,
      "label": "Enable loop autoplay"
    },
    {
      "type": "checkbox",
      "id": "auto_width",
      "default": false,
      "label": "Auto width"
    },
    {
      "type": "range",
      "id": "slider_speed",
      "min": 1000,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "label": "Loop speed",
      "default": 6000
    },
    {
      "type": "range",
      "id": "space_between_slide",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Space Between Slide",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "default": false,
      "label": "Show pagination"
    },
    {
      "type": "select",
      "id": "show_pagination_in",
      "options": [
        {
          "value": "both",
          "label": "Both"
        },
        {
          "value": "desktop",
          "label": "Desktop"
        },
        {
          "value": "mobile",
          "label": "Mobile"
        }
      ],
      "default": "both",
      "label": "Show pagination in"
    },
    {
      "type": "select",
      "id": "pagination_type",
      "options": [
        {
          "value": "dot",
          "label": "Dot"
        },
        {
          "value": "border",
          "label": "Dot border"
        },
        {
          "value": "line",
          "label": "Line"
        },
        {
          "value": "number",
          "label": "Number"
        }
      ],
      "default": "dot",
      "label": "Pagination type"
    },
    {
      "type": "checkbox",
      "id": "navigation",
      "label": "Show navigation",
      "default": true
    },
    {
      "type": "select",
      "id": "show_navigation_in",
      "options": [
        {
          "value": "both",
          "label": "Both"
        },
        {
          "value": "desktop",
          "label": "Desktop"
        },
        {
          "value": "mobile",
          "label": "Mobile"
        }
      ],
      "default": "both",
      "label": "Show navigation in"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "image_text_slide",
      "name": "Image text slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "Slide title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your slide text here.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image text slider",
      "blocks": [
        {
          "type": "image_text_slide"
        },
        {
          "type": "image_text_slide"
        },
        {
          "type": "image_text_slide"
        },
        {
          "type": "image_text_slide"
        }
      ]
    }
  ]
}
{% endschema %}
